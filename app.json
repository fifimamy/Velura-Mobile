      "package": "com.fifimamy.VexriaMedical"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/image99.png"
    },
    "plugins": [
      "expo-localization",
      "expo-font"
    ],
    "experiments": {},
    "extra": {
      "eas": {
        "projectId": "dcf4a337-5fe0-428f-b4d1-d7c5a59b3245"
      }
    }
  }
}
